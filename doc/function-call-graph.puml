@startuml
'=============================================================================
' UPFS 完整函数调用关系图
' 生成日期: 2026-06-01
' 项目: OS Design Course Project
'=============================================================================

skinparam backgroundColor #FEFEFE
skinparam packageBackgroundColor #F8F8F8
skinparam packageBorderColor #888888
skinparam componentBackgroundColor #E8F0FE
skinparam componentBorderColor #4060A0
skinparam noteBackgroundColor #FFFFE0
skinparam noteBorderColor #CCCC00

title UPFS — 函数调用关系全景图\n(所有函数、所在文件、功能、调用关系)

'=============================================================================
' PACKAGE: 入口与 Shell 层 (main.c)
'=============================================================================
package "Shell 层\n(main.c)" as Shell #LightBlue {

  component "main\n→ 入口函数: 解析 --serve 参数\n→ 调用: upfs_session|serve_main" as main
  component "upfs_session\n→ 交互式 Shell 主循环\n→ 调用: ui_banner,dispatch_command,shell_mount,shell_umount" as upfs_session

  component "current_user\n→ 获取当前登录用户" as current_user
  component "ui_banner\n→ 显示 ASCII 艺术 Banner" as ui_banner
  component "ui_ok / ui_info / ui_err\n→ 分别输出成功/信息/错误消息" as ui_status
  component "cwd_display\n→ 将路径 ~ 缩写格式化" as cwd_display
  component "ui_prompt\n→ 渲染交互式提示符 [user:~/path >]" as ui_prompt

  component "disk_file_exists\n→ 检查宿主机文件是否存在" as disk_file_exists
  component "probe_disk_at\n→ 在指定目录探测磁盘镜像" as probe_disk_at
  component "startup_disk_probe\n→ 启动时自动搜索磁盘镜像" as startup_disk_probe

  component "init_root_user\n→ 初始化 root 用户" as init_root_user
  component "shell_bind_user\n→ 绑定当前用户到目录系统" as shell_bind_user

  component "read_password\n→ 关闭回显读取密码" as read_password
  component "shell_login_prompt\n→ 登录交互：用户名+密码验证" as shell_login_prompt
  component "shell_create_first_user\n→ 首次运行时创建用户交互" as shell_create_first_user

  component "shell_mount\n→ 挂载命令：加载文件系统 + 初始化内核" as shell_mount
  component "shell_umount\n→ 卸载命令：保存并关闭文件系统" as shell_umount
  component "shell_format\n→ 格式化命令：创建新磁盘镜像" as shell_format

  component "cwd_resolve_dots\n→ 解析路径中的 . 和 .. 得到规范路径" as cwd_resolve_dots
  component "cwd_update_after_cd\n→ cd 后更新全局 CWD" as cwd_update_after_cd

  component "trim\n→ 去除字符串首尾空白" as trim
  component "parse_octal_mode\n→ 解析八进制权限字符串" as parse_octal_mode
  component "parse_command_line\n→ 将输入行解析为 argc/argv" as parse_command_line

  component "cmd_help\n→ 显示帮助菜单" as cmd_help
  component "require_mounted\n→ 检查文件系统是否已挂载" as require_mounted

  ' 文件操作命令
  component "cmd_cat\n→ cat: 读取并显示文件内容\n调用: vfs_open,vfs_read,vfs_close" as cmd_cat
  component "cmd_write_existing\n→ write: 写入文本到文件\n调用: vfs_open,vfs_create,vfs_write" as cmd_write_existing

  ' 用户操作命令
  component "cmd_useradd\n→ useradd: 添加新用户\n调用: user_add" as cmd_useradd
  component "cmd_login\n→ login: 用户名密码登录\n调用: user_verify" as cmd_login
  component "cmd_su\n→ su: 切换用户\n调用: user_verify" as cmd_su
  component "cmd_logout\n→ logout: 注销当前用户" as cmd_logout
  component "cmd_whoami\n→ whoami: 显示当前用户名" as cmd_whoami
  component "cmd_passwd\n→ passwd: 修改密码\n调用: user_passwd" as cmd_passwd
  component "cmd_users\n→ users: 列出所有用户\n调用: user_count,user_get" as cmd_users

  ' 进程/环境命令
  component "resolve_program_path\n→ 解析程序路径（无/则加 ./）" as resolve_program_path
  component "shell_vm_enter_raw\n→ 进入 raw 终端模式（VM 运行前）" as shell_vm_enter_raw
  component "shell_vm_leave_raw\n→ 恢复终端模式（VM 运行后）" as shell_vm_leave_raw
  component "cmd_run\n→ run: 分配进程并执行 .upx\n调用: proc_alloc,proc_exec,sched_enqueue,sched_tick" as cmd_run
  component "pipeline_program\n→ 提取管道段中的程序名" as pipeline_program
  component "proc_bind_pipe_in\n→ 绑定进程 stdin 到管道读取端" as proc_bind_pipe_in
  component "proc_bind_pipe_out\n→ 绑定进程 stdout 到管道写入端" as proc_bind_pipe_out
  component "cmd_run_pipeline_chain\n→ 管道链: 创建多个进程+管道串联\n调用: proc_alloc,pipe_alloc,proc_exec,sched_enqueue" as cmd_run_pipeline_chain
  component "split_pipeline_segments\n→ 按 | 分割管道阶段" as split_pipeline_segments
  component "try_run_pipeline\n→ 检测并尝试作为管道执行" as try_run_pipeline
  component "cmd_kill_cmd\n→ kill: 向进程发送信号\n调用: ipc_kill" as cmd_kill_cmd
  component "cmd_mkfifo\n→ mkfifo: 创建命名 FIFO\n调用: ipc_mkfifo" as cmd_mkfifo

  ' 调试命令
  component "cmd_design_debug\n→ design_debug: 显示 OS 内部状态" as cmd_design_debug
  component "cmd_ps\n→ ps: 列出进程表\n调用: proc_get_table" as cmd_ps

  ' 环境变量命令
  component "env_print_cb\n→ env 回调：打印单条环境变量" as env_print_cb
  component "cmd_env\n→ env: 遍历并打印所有环境变量\n调用: env_foreach" as cmd_env
  component "cmd_export\n→ export: 设置环境变量\n调用: env_set" as cmd_export
  component "cmd_unset\n→ unset: 删除环境变量\n调用: env_unset" as cmd_unset

  ' 命令分发
  component "dispatch_command\n→ 命令路由: 根据 argv[0] 分发到各 cmd_*" as dispatch_command
}

'=============================================================================
' PACKAGE: TCP 服务器层 (serve.c)
'=============================================================================
package "TCP 服务器层\n(serve.c)" as Serve #LightCoral {

  component "serve_main\n→ 多终端 TCP 服务器主循环\n→ 监听 :8080 HTTP + :4096 TCP\n→ 调用: tcp_listen,poll,term_spawn,api_spawn,ws_send" as serve_main

  component "shared_disk_path\n→ 获取共享磁盘路径" as shared_disk_path
  component "shared_set_disk\n→ 设置共享磁盘路径" as shared_set_disk

  component "sha1_t / sha1_u / sha1_f / sha1_hash\n→ SHA1 哈希运算（WebSocket 握手）" as sha1
  component "b64enc\n→ Base64 编码" as b64enc

  component "nb_write\n→ 非阻塞 write（带 poll 重试）" as nb_write
  component "ws_send\n→ WebSocket 帧发送" as ws_send
  component "ws_recv\n→ WebSocket 帧接收与解包" as ws_recv
  component "http_send\n→ HTTP 响应发送" as http_send

  component "term_spawn\n→ fork 子进程运行 upfs_session" as term_spawn
  component "api_spawn\n→ fork 子进程运行 upfs_api_session" as api_spawn
  component "tcp_listen\n→ 创建 TCP 监听 socket" as tcp_listen

  component "conn_close\n→ 关闭连接并清理资源" as conn_close
  component "conn_alloc\n→ 分配连接槽位" as conn_alloc
}

'=============================================================================
' PACKAGE: Web API 层 (web_api.c)
'=============================================================================
package "Web API 层\n(web_api.c)" as WebAPI #LemonChiffon {

  component "upfs_api_session\n→ Web API 会话主循环\n→ 逐行读取 JSON 请求并分发" as upfs_api_session

  component "json_parse\n→ 简易 JSON 解析器" as json_parse
  component "json_get\n→ JSON 字段值获取" as json_get
  component "json_print_str\n→ JSON 字符串转义输出" as json_print_str

  component "api_start_response\n→ API 响应头（含回调 ID）" as api_start_response
  component "api_ok / api_err\n→ API 成功/错误响应" as api_ok_err

  component "proc_state_str\n→ 进程状态码→字符串" as proc_state_str

  component "cmd_ls\n→ API: 列出目录\n调用: namei,extent_lookup,read_block,iget" as api_cmd_ls
  component "cmd_stat\n→ API: 文件状态\n调用: vfs_stat" as api_cmd_stat
  component "cmd_cat\n→ API: 读取文件\n调用: vfs_open,vfs_read" as api_cmd_cat
  component "cmd_mkdir\n→ API: 创建目录\n调用: vfs_mkdir" as api_cmd_mkdir
  component "cmd_create\n→ API: 创建文件\n调用: vfs_create" as api_cmd_create
  component "cmd_rm\n→ API: 删除文件\n调用: vfs_delete" as api_cmd_rm
  component "cmd_debug_super\n→ API: 超级块调试\n调用: fs_get_superblock" as api_cmd_debug_super
  component "cmd_debug_process\n→ API: 进程调试\n调用: proc_get_table" as api_cmd_debug_process
  component "cmd_debug_memory\n→ API: 内存调试\n调用: mem_free_page_count,mem_get_page_bitmap" as api_cmd_debug_memory
  component "cmd_debug_all\n→ API: 所有调试信息" as api_cmd_debug_all

  component "try_mount\n→ API 延迟挂载" as api_try_mount
  component "dispatch\n→ API 命令路由" as api_dispatch
}

'=============================================================================
' PACKAGE: 文件系统 — 磁盘 I/O (fs/disk_io.c)
'=============================================================================
package "磁盘 I/O\n(fs/disk_io.c)" as DiskIO #Lavender {

  component "disk_create\n→ 在内存中创建空白磁盘（calloc）" as disk_create
  component "disk_load\n→ 通过 mmap 加载磁盘镜像文件" as disk_load
  component "disk_save\n→ 将内存磁盘写入文件" as disk_save
  component "disk_sync\n→ 将内存磁盘 msync 到文件" as disk_sync
  component "disk_shutdown\n→ 释放/unmap 磁盘内存" as disk_shutdown
  component "disk_read_block\n→ 读取一个磁盘块到缓冲区" as disk_read_block
  component "disk_write_block\n→ 将缓冲区写入一个磁盘块" as disk_write_block
  component "disk_memory\n→ 获取磁盘内存指针" as disk_memory
  component "disk_memory_size\n→ 获取磁盘总字节数" as disk_memory_size
  component "disk_check_block\n→ [static] 校验块号是否合法" as disk_check_block
  component "ensure_parent_dir\n→ [static] 确保宿主机父目录存在" as ensure_parent_dir
}

'=============================================================================
' PACKAGE: 文件系统 — 格式化 (fs/format.c)
'=============================================================================
package "格式化\n(fs/format.c)" as Format #Thistle {

  component "format\n→ 创建新文件系统: 引导块→块组→日志→imap→根目录\n→ 调用: disk_create,bg_format_init,journal_init_format,inomap_format_init,disk_save" as format
  component "init_boot_block\n→ [static] 初始化引导块 (UPFSBOOT 魔数)" as init_boot_block
  component "init_root_directory\n→ [static] 初始化根目录 (. 和 ..)" as init_root_directory
}

'=============================================================================
' PACKAGE: 文件系统 — 块组管理 (fs/bg.c)
'=============================================================================
package "块组管理\n(fs/bg.c)" as BG #MistyRose {

  component "bg_from_block\n→ 由块号计算所属块组编号" as bg_from_block
  component "bg_block_in_data_zone\n→ 判断块是否在数据区" as bg_block_in_data_zone
  component "bg_is_inode_disk_block\n→ 判断是否为 inode chunk 块" as bg_is_inode_disk_block
  component "bg_is_anchor_block\n→ 判断是否为锚点块" as bg_is_anchor_block
  component "bg_format_init\n→ 格式化块组空闲块栈\n→ 调用: bg_build_layout,bg_init_free_stack,bg_write_anchor" as bg_format_init
  component "bg_init_from_super\n→ 从超级块恢复块组运行时数据\n→ 调用: bg_build_layout,bg_read_anchor" as bg_init_from_super
  component "bg_fill_super\n→ 将块组统计信息写入超级块\n→ 调用: inomap_sync" as bg_fill_super
  component "bg_sync\n→ 同步所有块组锚点块到磁盘" as bg_sync
  component "bg_balloc_for\n→ 为指定 inode 优先分配同组数据块\n→ 调用: bg_hint_to_group,bg_reload_free_stack" as bg_balloc_for
  component "bg_bfree\n→ 释放一个数据块回空闲链" as bg_bfree
  component "bg_debug_print\n→ 打印块组空闲状态" as bg_debug_print
  component "bg_group_free\n→ 获取指定块组的空闲块数" as bg_group_free

  component "bg_build_layout\n→ [static] 计算块组锚点/数据区布局" as bg_build_layout
  component "bg_init_free_stack\n→ [static] 初始化空闲块成组链接栈" as bg_init_free_stack
  component "bg_write_anchor\n→ [static] 将锚点数据写入磁盘" as bg_write_anchor
  component "bg_read_anchor\n→ [static] 从磁盘读取锚点数据" as bg_read_anchor
  component "bg_reload_free_stack\n→ [static] 从链头块重新加载空闲栈" as bg_reload_free_stack
  component "bg_hint_to_group\n→ [static] 根据 inode 所在块推断块组" as bg_hint_to_group
  component "reg_header_valid\n→ [static] 校验成组链头" as reg_header_valid
}

'=============================================================================
' PACKAGE: 文件系统 — 块缓存 (fs/buf.c)
'=============================================================================
package "块缓存\n(fs/buf.c)" as Buf #Honeydew {

  component "buf_init\n→ 初始化 LRU+哈希块缓存" as buf_init
  component "buf_shutdown\n→ 关闭缓存（刷脏）" as buf_shutdown
  component "bread\n→ 读取块到缓存并返回 Buf*" as bread
  component "brelse\n→ 释放缓存引用" as brelse
  component "bwrite\n→ 同步写脏块到磁盘" as bwrite
  component "bdwrite\n→ 标记脏块并释放（延迟写）" as bdwrite
  component "bflush_all\n→ 刷新所有脏块" as bflush_all
  component "read_block\n→ 便捷读块 (bread + memcpy + brelse)" as read_block
  component "write_block\n→ 便捷写块 (bread + memcpy + bdwrite)" as write_block

  component "buf_hash_key\n→ [static] 计算哈希键" as buf_hash_key
  component "lru_remove / lru_insert_mru\n→ [static] LRU 链表操作" as lru_ops
  component "buf_hash_find / buf_hash_insert / buf_hash_remove\n→ [static] 哈希表操作" as hash_ops
  component "buf_invalidate\n→ [static] 失效一个缓存槽" as buf_invalidate
  component "buf_alloc_slot\n→ [static] 分配空闲缓存槽" as buf_alloc_slot
}

'=============================================================================
' PACKAGE: 文件系统 — 日志 (fs/journal.c)
'=============================================================================
package "日志\n(fs/journal.c)" as Journal #LavenderBlush {

  component "journal_is_metadata_block\n→ 判断是否为元数据块" as journal_is_metadata_block
  component "journal_init_format\n→ 格式化时初始化日志区" as journal_init_format
  component "journal_replay\n→ 挂载时回放已提交日志" as journal_replay
  component "journal_begin\n→ 开启事务" as journal_begin
  component "journal_log_block\n→ 记录块变更到事务" as journal_log_block
  component "journal_abort\n→ 中止事务" as journal_abort
  component "journal_commit\n→ 提交事务: 写日志→写数据→刷新缓存" as journal_commit
  component "journal_write_metadata\n→ 元数据块写（自动判断是否日志）\n→ 调用: journal_write_logged或write_block" as journal_write_metadata
  component "journal_write_dir_block\n→ 目录数据块写（日志保护）\n→ 调用: journal_write_logged或write_block" as journal_write_dir_block

  component "journal_header_block / journal_data_block\n→ [static] 计算日志头/数据块号" as journal_block_pos
  component "journal_read_header\n→ [static] 读取日志头" as journal_read_header
  component "journal_apply_log\n→ [static] 应用一条日志记录到磁盘" as journal_apply_log
  component "journal_write_logged\n→ [static] 自动 begin→log→commit" as journal_write_logged
}

'=============================================================================
' PACKAGE: 文件系统 — 动态 Inode 映射 (fs/inomap.c)
'=============================================================================
package "动态 Inode 映射\n(fs/inomap.c)" as InoMap #Seashell {

  component "inomap_is_chunk_block\n→ 判断块号是否为 inode chunk" as inomap_is_chunk_block
  component "inomap_lookup\n→ 查询 inode 所在的 chunk+偏移" as inomap_lookup
  component "inomap_read_disk_inode\n→ 从磁盘读取 DiskINode" as inomap_read_disk_inode
  component "inomap_write_disk_inode\n→ 将 DiskINode 写入磁盘" as inomap_write_disk_inode
  component "inomap_ialloc_for\n→ 分配新 inode（优先同块组）\n→ 调用: imap_pop_free,chunk_find_free_slot,chunk_alloc_new,loc_insert" as inomap_ialloc_for
  component "inomap_ifree\n→ 释放 inode 回空闲池" as inomap_ifree
  component "inomap_format_init\n→ 格式化时初始化 inode 映射\n→ 调用: chunk_alloc_new,loc_insert" as inomap_format_init
  component "inomap_load\n→ 从超级块恢复 imap 运行时数据" as inomap_load
  component "inomap_sync\n→ 将 imap 运行时数据写入超级块" as inomap_sync
  component "inomap_debug_print\n→ 打印 imap 状态" as inomap_debug_print

  component "imap_blk_read / imap_write_blk\n→ [static] 读/写 imap 块（格式化时用 disk，运行时用 buf+journal）" as imap_blk_rw
  component "imap_leaf_read / imap_leaf_write\n→ [static] B+树叶节点读写" as imap_leaf_rw
  component "imap_index_read / imap_index_write\n→ [static] B+树索引节点读写" as imap_index_rw
  component "imap_alloc_meta\n→ [static] 为 B+树分配一个元数据块\n→ 调用: bg_balloc_for" as imap_alloc_meta
  component "loc_find_leaf / loc_lookup / loc_insert / loc_split_leaf\n→ [static] B+树 (location) 查找/插入/分裂" as loc_ops
  component "chk_get / chk_set\n→ [static] Chunk 位图读/写" as chk_ops
  component "chunk_find_free_slot / chunk_alloc_new\n→ [static] 查找空闲 inode 槽/分配新 chunk" as chunk_ops
  component "imap_push_free / imap_pop_free\n→ [static] Inode 号回收栈" as imap_free_stack
}

'=============================================================================
' PACKAGE: 文件系统 — Extent 树 (fs/extent.c)
'=============================================================================
package "Extent 树\n(fs/extent.c)" as Extent #PapayaWhip {

  component "extent_lookup\n→ 根据逻辑块号查找物理块号\n→ 调用: find_leaf_for_lblk,leaf_lookup_blk" as extent_lookup
  component "extent_clear\n→ 释放文件的全部 extent 和物理块\n→ 调用: free_tree,bfree" as extent_clear
  component "extent_set_single\n→ 设置单个 extent（清空旧树）" as extent_set_single
  component "extent_bmap\n→ 块映射: 查找或分配新块\n→ 调用: extent_lookup,balloc_for,insert_extent" as extent_bmap

  component "extent_in_range / extent_phys_at\n→ [static] 判断 lblk 是否在 extent 内/计算物理块号" as extent_helpers
  component "leaf_read / leaf_write\n→ [static] Extent 叶节点读写" as leaf_rw
  component "index_read / index_write\n→ [static] Extent 索引节点读写" as index_rw
  component "find_leaf_for_lblk\n→ [static] 在索引树中定位叶节点" as find_leaf_for_lblk
  component "leaf_lookup_blk\n→ [static] 在叶节点中查找块映射" as leaf_lookup_blk
  component "try_merge_adjacent\n→ [static] 合并相邻 extent" as try_merge_adjacent
  component "alloc_metadata_block\n→ [static] 分配 extent 树的元数据块\n→ 调用: balloc_for" as alloc_metadata_block
  component "insert_into_leaf_blk\n→ [static] 插入 extent 到指定叶节点" as insert_into_leaf_blk
  component "insert_extent\n→ [static] 插入 extent（可能分裂为 B+树）\n→ 调用: alloc_metadata_block,insert_into_leaf_blk" as insert_extent
  component "free_leaf_blocks\n→ [static] 递归释放叶节点中的全部数据块" as free_leaf_blocks
  component "free_tree\n→ [static] 递归释放整个 extent B+树" as free_tree
}

'=============================================================================
' PACKAGE: 文件系统 — 分配器 (fs/allocator.c)
'=============================================================================
package "分配器\n(fs/allocator.c)" as Alloc #PowderBlue {

  component "fs_mount\n→ 挂载文件系统\n→ 调用: disk_load,read_block,bg_init_from_super,inomap_load" as fs_mount
  component "fs_sync_superblock\n→ 同步超级块\n→ 调用: bg_fill_super,bg_sync,journal_write_metadata" as fs_sync_superblock
  component "fs_sync_disk\n→ 全量同步: 刷脏 inode+超级块+磁盘\n→ 调用: bflush_all,write_disk_inode,fs_sync_superblock,disk_sync" as fs_sync_disk
